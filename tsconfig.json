{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"lib": ["ES2022"],
		"moduleResolution": "node",
		"outDir": "./dist",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"noImplicitAny": false
	},
	"include": ["credentials/**/*.ts", "nodes/**/*.ts", "utils/**/*.ts"],
	"exclude": ["node_modules", "dist", "test"]
}
