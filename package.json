{
	"name": "n8n-nodes-voyageai",
	"version": "0.1.0",
	"description": "n8n community node for VoyageAI embeddings and reranking",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"author": {
		"name": "Zoltan Fodi"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fodizoltan/n8n-nodes-voyageai.git"
	},
	"main": "dist/nodes/EmbeddingsVoyageAi/EmbeddingsVoyageAi.node.js",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc && copyfiles \"credentials/**/*.svg\" \"nodes/**/*.svg\" dist/",
		"dev": "tsc --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"test": "jest",
		"test:unit": "jest --testPathPattern=test/unit",
		"test:integration": "jest --testPathPattern=test/integration",
		"test:coverage": "jest --testPathPattern=test/unit --coverage",
		"prepublishOnly": "npm run build"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/VoyageAiApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/EmbeddingsVoyageAi/EmbeddingsVoyageAi.node.js",
			"dist/nodes/EmbeddingsVoyageAiMultimodal/EmbeddingsVoyageAiMultimodal.node.js",
			"dist/nodes/EmbeddingsVoyageAiContextualized/EmbeddingsVoyageAiContextualized.node.js",
			"dist/nodes/RerankerVoyageAi/RerankerVoyageAi.node.js"
		]
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"@langchain/community": "^0.3.50",
		"@langchain/core": "^0.3.68",
		"proxy-from-env": "^1.1.0",
		"undici": "^6.0.0",
		"voyageai": "^0.2.1"
	},
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"@types/node": "^20.17.12",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"copyfiles": "^2.4.1",
		"eslint": "^8.57.0",
		"jest": "^29.7.0",
		"jest-mock-extended": "^3.0.7",
		"n8n-workflow": "*",
		"prettier": "^3.3.0",
		"ts-jest": "^29.2.0",
		"typescript": "~5.7.0"
	}
}
